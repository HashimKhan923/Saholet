APP_NAME=sahoulat
APP_ENV=local
APP_KEY=
# SECURITY: must be false in production — leaving this true leaks stack traces,
# env values, and query bindings to anyone who triggers an error.
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_CONTACT_TO="info@sahoulat.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Reverb (real-time broadcasting: chat, tracking, notifications) ──────────
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="127.0.0.1"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Payments (config/payment.php) ───────────────────────────────────────────
# driver: mock | jazzcash | easypaisa. Gateways stay inert until *_ENABLED=true
# and their credentials are set — safe to leave unset in development.
PAYMENT_DRIVER=mock
PAYMENT_RELEASE_MODE=consumer_confirm

JAZZCASH_ENABLED=false
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
# sandbox | production
JAZZCASH_ENV=sandbox

EASYPAISA_ENABLED=false
EASYPAISA_STORE_ID=
EASYPAISA_ACCOUNT=
EASYPAISA_HASH_KEY=
EASYPAISA_ENV=sandbox

# ─── Notifications (config/notifications.php) — in-app + log are always on ──
NOTIFY_MAIL=true
NOTIFY_SMS=false
SMS_GATEWAY=
SMS_API_KEY=
SMS_SENDER=

NOTIFY_WHATSAPP=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

NOTIFY_PUSH=false
# Generate with: php artisan tinker --execute="print_r(Minishlink\WebPush\VAPID::createVapidKeys());"
# On Windows/XAMPP, openssl_pkey_new() needs a valid config file or it fails
# with "Unable to create the key" — prefix the command with:
#   OPENSSL_CONF="C:\xampp\php\extras\openssl\openssl.cnf"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:support@example.com"
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"
